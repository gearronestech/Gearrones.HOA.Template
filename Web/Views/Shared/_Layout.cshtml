@inject IHoaClientContext Hoa
@inject GearrOnes.HOA.Template.Features.Shared.Navigation.INavigationService NavService
@inject IHttpContextAccessor HttpContextAccessor
@inject GearrOnes.HOA.Template.Features.Notifications.Services.INotificationService NotificationService
@{
    var user = HttpContextAccessor.HttpContext?.User ?? new System.Security.Claims.ClaimsPrincipal();
    var navItems = NavService.GetMainNavigation(user);
    var currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "homeowner-1";
    var notifications = user.Identity?.IsAuthenticated ?? false ? await NotificationService.GetForUserAsync(currentUserId, 5, Context.RequestAborted) : [];
    var unreadCount = user.Identity?.IsAuthenticated ?? false ? await NotificationService.GetUnreadCountAsync(currentUserId, Context.RequestAborted) : 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Hoa.PortalTitle</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <header class="border-bottom mb-3">
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container-fluid">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-dark me-3">
                    @await Html.PartialAsync("_HoaHeader", Hoa)
                </a>
                <div class="collapse navbar-collapse show" id="mainNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
                        @foreach (var item in navItems)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="@item.Controller" asp-action="@item.Action">@item.Title</a></li>
                        }
                        @if (user.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Notifications (@unreadCount)</a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @foreach (var n in notifications)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Notifications" asp-action="Index">@n.Title</a></li>
                                    }
                                    <li><a class="dropdown-item text-primary" asp-controller="Notifications" asp-action="Index">View all</a></li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post"><button type="submit" class="btn btn-link nav-link">Logout</button></form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted mt-4 py-3">
        <div class="container">
            @Hoa.LegalName
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>