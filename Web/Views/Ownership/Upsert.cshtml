@model GearrOnes.HOA.Template.Features.Ownership.ViewModels.UpsertPropertyOwnershipViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Edit Ownership" : "Add Ownership";
}
<h1>@ViewData["Title"]</h1>
<form method="post">
    <input asp-for="Id" type="hidden" />
    <div class="mb-3"><label asp-for="PropertyId"></label><select asp-for="PropertyId" asp-items="ViewBag.Properties" class="form-select"></select></div>
    <div class="mb-3"><label asp-for="PersonId"></label><select asp-for="PersonId" asp-items="ViewBag.People" class="form-select"></select></div>
    <div class="mb-3"><label asp-for="StartDate"></label><input asp-for="StartDate" type="date" class="form-control" /></div>
    <div class="mb-3"><label asp-for="EndDate"></label><input asp-for="EndDate" type="date" class="form-control" /></div>
    <div class="mb-3"><label asp-for="ClosingReference"></label><input asp-for="ClosingReference" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Notes"></label><textarea asp-for="Notes" class="form-control"></textarea></div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>