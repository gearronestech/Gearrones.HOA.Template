@model GearrOnes.HOA.Template.Features.Requests.ViewModels.RequestDetailViewModel
@{
    ViewData["Title"] = "Request Details";
}

<h1>@Model.Request.Title</h1>
<p><strong>Status:</strong> @Model.Request.Status</p>
<p><strong>Submitted:</strong> @Model.Request.CreatedUtc.ToString("u")</p>
<p>@Model.Request.Description</p>

<h2>Attachments</h2>
@if (!Model.Attachments.Any())
{
    <p class="text-muted">No attachments uploaded yet.</p>
}
else
{
    <ul class="list-group mb-3">
        @foreach (var attachment in Model.Attachments)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <a asp-action="DownloadAttachment" asp-route-id="@attachment.AttachmentId">@attachment.OriginalFileName</a>
                    <small class="text-muted d-block">Uploaded by @attachment.UploadedByDisplayName on @attachment.CreatedUtc.ToString("u")</small>
                </div>
                <span class="badge text-bg-secondary">@attachment.FileSize bytes</span>
            </li>
        }
    </ul>
}

<h3>Upload attachment</h3>
<form asp-action="UploadAttachment" method="post" enctype="multipart/form-data" class="mb-4">
    <input type="hidden" name="RequestId" value="@Model.Request.Id" />
    <div class="mb-3">
        <input class="form-control" type="file" name="File" />
        <small class="text-muted">Allowed: .pdf, .png, .jpg, .jpeg, .doc, .docx, .txt. Max 10 MB.</small>
    </div>
    <button class="btn btn-outline-primary" type="submit">Upload</button>
</form>

<h2>Conversation</h2>
@foreach (var item in Model.Timeline)
{
    <div class="card mb-2 @(item.IsInternalNote ? "border-warning" : "")">
        <div class="card-body">
            @if (item.IsInternalNote)
            {
                <div class="badge bg-warning text-dark mb-2">Internal note</div>
            }
            <div><strong>@item.UserDisplayName</strong> <small class="text-muted">@item.CreatedUtc.ToString("u")</small></div>
            <div>@item.Message</div>
        </div>
    </div>
}

<h3>Add message</h3>
<form asp-action="AddMessage" method="post">
    <input type="hidden" name="RequestId" value="@Model.Request.Id" />
    <div class="mb-3">
        <textarea class="form-control" name="Message" rows="4"></textarea>
    </div>
    @if (Model.CanCreateInternalNote)
    {
        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" value="true" name="IsInternalNote" id="isInternalNote" />
            <label class="form-check-label" for="isInternalNote">Post as internal note (board/admin only)</label>
        </div>
    }
    <button class="btn btn-primary" type="submit">Send</button>
</form>